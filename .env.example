# =============================================================================
# HiBob Hiring API
# =============================================================================

# Your HiBob API service account ID (found in HiBob → Settings → API)
HIBOB_API_ID=your-hibob-api-id

# Your HiBob API token (paired with the API ID above)
HIBOB_API_TOKEN=your-hibob-api-token


# =============================================================================
# Webflow CMS API
# =============================================================================

# Webflow API token (Settings → Integrations → API Access → Generate token)
# Requires CMS read+write scope for your site.
WEBFLOW_API_TOKEN=your-webflow-api-token

# The ID of the Webflow CMS collection where jobs are stored.
# Find it: Webflow Designer → CMS → Jobs collection → Settings, or via
#   GET https://api.webflow.com/v2/sites/{site_id}/collections
WEBFLOW_COLLECTION_ID=your-webflow-collection-id


# =============================================================================
# Sync endpoint security
# =============================================================================

# Secret token used to authenticate calls to POST /api/sync-jobs.
# Generate with: openssl rand -base64 32
SYNC_SECRET=your-random-secret-here

# Vercel injects this automatically for cron requests when set in the dashboard.
# Set the same value in Vercel → Project → Settings → Environment Variables.
# Docs: https://vercel.com/docs/cron-jobs/manage-cron-jobs#securing-cron-jobs
CRON_SECRET=your-vercel-cron-secret


# =============================================================================
# Optional
# =============================================================================

# Set to "debug" to enable verbose logging (e.g. per-page Webflow fetch logs).
# LOG_LEVEL=debug
