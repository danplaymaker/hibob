# ─── Data Provider ────────────────────────────────────────────────────────────
# Which data source to use: "mock" | "betfair" | "composite"
ODDS_PROVIDER=mock

# ─── Betfair API Credentials ─────────────────────────────────────────────────
# Required when ODDS_PROVIDER=betfair or ODDS_PROVIDER=composite
#
# Get your app key at: https://developer.betfair.com/
BETFAIR_APP_KEY=
BETFAIR_USERNAME=
BETFAIR_PASSWORD=

# Certificate-based login (recommended for server/automated use)
# Generate a self-signed cert and register it with Betfair:
#   openssl req -x509 -newkey rsa:2048 -keyout betfair.key -out betfair.crt -days 365 -nodes
# Then upload betfair.crt at: https://developer.betfair.com/
# If omitted, falls back to interactive (username/password) login
BETFAIR_CERT_PATH=
BETFAIR_KEY_PATH=

# ─── Bookmaker Odds (Phase 2) ────────────────────────────────────────────────
# API key for The Odds API (https://the-odds-api.com/)
# ODDS_API_KEY=

# ─── App Settings ────────────────────────────────────────────────────────────
# Polling interval in milliseconds (default 5000)
POLL_INTERVAL_MS=5000

# Alert settings
ALERT_SOUND_ENABLED=true
BROWSER_NOTIFICATIONS_ENABLED=true
